# ============================
# Node.js - Archivos comunes
# ============================

# Dependencias
node_modules/

# Archivos de logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Archivos del sistema
.DS_Store
Thumbs.db

# Entorno
.env
.env.*.local
.env.local

# Compilación / Builds
dist/
build/
out/
tmp/
temp/

# Cache de paquetes
.npm/
.yarn-cache/
.pnpm-store/

# Coverage (pruebas)
coverage/
.nyc_output/

# Carpetas de herramientas
.lib/
.cache/
.eslintcache

# IDEs
.vscode/
.idea/

# PM2 logs
.pids
*.pid
*.seed
*.pid.lock

# TypeScript
*.tsbuildinfo

# Sentry
.sentrycli/

# Next.js (si aplica)
.next/
.vercel/

# Remix / Astro / Otros frameworks
.server/
.output/
